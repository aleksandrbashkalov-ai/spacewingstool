{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "default_agent": "build",
  "logLevel": "INFO",
  "permission": {
    "bash": {
      "swift build*": "allow",
      "swift test*": "allow",
      "swift run*": "allow",
      "xed *": "allow",
      "log stream*": "ask",
      "sudo *": "ask",
      "rm *": "deny",
      "*": "ask"
    },
    "edit": "allow"
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.github.com/mcp",
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    }
  }
}
